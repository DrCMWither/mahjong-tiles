\cs_new_protected:Npn \__pongtex_set_local_defaults:
  {
    \dim_set_eq:NN \l__pongtex_tile_height_dim \g__pongtex_default_height_dim
    \fp_set_eq:NN  \l__pongtex_tile_scale_fp  \g__pongtex_default_scale_fp
    \int_set_eq:NN \l__pongtex_river_cols_int \g__pongtex_river_cols_int
    \dim_set_eq:NN \l__pongtex_river_row_gap_dim \g__pongtex_river_row_gap_dim
  }

\cs_new_protected:Npn \__pongtex_apply_local_options:nnnn #1#2#3#4
  {
    \__pongtex_set_local_defaults:
    \tl_if_in:nnTF {#1} { = }
      { \keys_set:nn { pongtex / local } {#1} }
      {
        \dim_set:Nn \l__pongtex_tile_height_dim {#1}
        \fp_set:Nn  \l__pongtex_tile_scale_fp  {#2}
        \IfNoValueF {#3}
          { \__pongtex_set_back_color_local:n {#3} }
      }
    \tl_if_blank:nF {#4}
      { \keys_set:nn { pongtex / local } {#4} }
  }

\cs_new_protected:Npn \pongtex_typeset_hand:n #1
  {
    \group_begin:
      \__pongtex_set_local_defaults:
      \__pongtex_render_hand:n {#1}
    \group_end:
  }

\cs_new_protected:Npn \pongtex:n #1
  { \pongtex_typeset_hand:n {#1} }

\cs_new_protected:Npn \pongtex_typeset_river:n #1
