      },
    5k .code:n =
      {
        \int_set:Nn \l__mahjongtiles_stick_fivek_int {#1}
        \bool_set_true:N \l__mahjongtiles_stick_manual_bool
      },
    1k .code:n =
      {
        \int_set:Nn \l__mahjongtiles_stick_onek_int {#1}
        \bool_set_true:N \l__mahjongtiles_stick_manual_bool
      },
    100 .code:n =
      {
        \int_set:Nn \l__mahjongtiles_stick_hundred_int {#1}
        \bool_set_true:N \l__mahjongtiles_stick_manual_bool
      },

    10000 .meta:n = { 10k = #1 },
    5000 .meta:n = { 5k = #1 },
    1000 .meta:n = { 1k = #1 },
    ten-thousand .meta:n = { 10k = #1 },
    five-thousand .meta:n = { 5k = #1 },
    thousand .meta:n = { 1k = #1 },
    hundred .meta:n = { 100 = #1 },
