    sep .dim_set:N = \l__mahjongtiles_stick_sep_dim,
    sep .value_required:n = true,
    stick-dir .tl_set:N = \l__mahjongtiles_stick_dir_tl,
    stick-dir .value_required:n = true,
    dir .tl_set:N = \l__mahjongtiles_stick_dir_tl,
    dir .value_required:n = true,

    manual .choice:,
    manual / true .code:n = { \bool_set_true:N \l__mahjongtiles_stick_manual_bool },
