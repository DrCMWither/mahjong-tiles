%<*package>
% -----------------------------------------------------------------------------
% Package options and state
% -----------------------------------------------------------------------------
\dim_new:N \g__mahjongtiles_default_height_dim
\fp_new:N  \g__mahjongtiles_default_scale_fp
\tl_new:N  \g__mahjongtiles_tile_dir_tl
\int_new:N \g__mahjongtiles_river_cols_int
\dim_new:N \g__mahjongtiles_river_row_gap_dim
\tl_new:N  \g__mahjongtiles_stick_dir_tl
\dim_new:N \g__mahjongtiles_stick_height_dim
\fp_new:N  \g__mahjongtiles_stick_scale_fp
\dim_new:N \g__mahjongtiles_stick_sep_dim

\dim_gset:Nn \g__mahjongtiles_default_height_dim { \baselineskip }
\fp_gset:Nn  \g__mahjongtiles_default_scale_fp  { 0.75 }
\tl_gset:Nn  \g__mahjongtiles_tile_dir_tl       { tiles }
\int_gset:Nn \g__mahjongtiles_river_cols_int    { 6 }
\dim_gset:Nn \g__mahjongtiles_river_row_gap_dim { 0pt }
\tl_gset:Nn  \g__mahjongtiles_stick_dir_tl      { assets/stick }
\dim_gset:Nn \g__mahjongtiles_stick_height_dim  { \baselineskip }
\fp_gset:Nn  \g__mahjongtiles_stick_scale_fp   { 0.5 }
\dim_gset:Nn \g__mahjongtiles_stick_sep_dim     { .6em }

\tl_new:N   \g__mahjongtiles_back_color_tl
\tl_new:N   \g__mahjongtiles_overlay_style_tl
\bool_new:N \g__mahjongtiles_back_recolor_bool
\int_new:N  \g__mahjongtiles_aka_int

\tl_gclear:N \g__mahjongtiles_back_color_tl
\tl_gset:Nn \g__mahjongtiles_overlay_style_tl
  {
    font = \scriptsize,
    align = center,
    anchor = south,
    inner~sep = 0.2pt,
    outer~sep = 0pt,
    yshift = 0.35em
  }

\bool_gset_false:N \g__mahjongtiles_back_recolor_bool
\int_gset:Nn \g__mahjongtiles_aka_int { 1 }

\cs_new_protected:Npn \__mahjongtiles_set_back_color_global:n #1
  {
    \tl_if_blank:nTF {#1}
      {
        \tl_gclear:N \g__mahjongtiles_back_color_tl
        \bool_gset_false:N \g__mahjongtiles_back_recolor_bool
      }
      {
        \str_if_eq:nnTF {#1} { none }
          {
            \tl_gclear:N \g__mahjongtiles_back_color_tl
            \bool_gset_false:N \g__mahjongtiles_back_recolor_bool
          }
          {
            \tl_gset:Nn \g__mahjongtiles_back_color_tl {#1}
            \bool_gset_true:N \g__mahjongtiles_back_recolor_bool
          }
      }
  }

\cs_new_protected:Npn \__mahjongtiles_set_back_color_local:n #1
  {
    \tl_if_blank:nTF {#1}
      {
        \tl_clear:N \g__mahjongtiles_back_color_tl
        \bool_set_false:N \g__mahjongtiles_back_recolor_bool
      }
      {
        \str_if_eq:nnTF {#1} { none }
          {
            \tl_clear:N \g__mahjongtiles_back_color_tl
            \bool_set_false:N \g__mahjongtiles_back_recolor_bool
          }
          {
            \tl_set:Nn \g__mahjongtiles_back_color_tl {#1}
            \bool_set_true:N \g__mahjongtiles_back_recolor_bool
          }
      }
  }

\cs_new_protected:Npn \__mahjongtiles_set_aka_global:n #1
  {
    \str_case:nnF {#1}
      {
        { 0 } { \int_gset:Nn \g__mahjongtiles_aka_int {0} }
        { 1 } { \int_gset:Nn \g__mahjongtiles_aka_int {1} }
        { 2 } { \int_gset:Nn \g__mahjongtiles_aka_int {2} }
      }
      { \msg_error:nnn { mahjong-tiles } { invalid-aka } { aka=#1 } }
  }

\cs_new_protected:Npn \__mahjongtiles_set_aka_local:n #1
  {
    \str_case:nnF {#1}
      {
        { 0 } { \int_set:Nn \g__mahjongtiles_aka_int {0} }
        { 1 } { \int_set:Nn \g__mahjongtiles_aka_int {1} }
        { 2 } { \int_set:Nn \g__mahjongtiles_aka_int {2} }
      }
      { \msg_error:nnn { mahjong-tiles } { invalid-aka } { aka=#1 } }
  }

\cs_new_protected:Npn \__mahjongtiles_warn_deprecated_no_aka:nn #1#2
  { \msg_warning:nnnn { mahjong-tiles } { deprecated-no-aka } {#1} {#2} }

\cs_new_protected:Npn \__mahjongtiles_set_no_aka_global:n #1
  {
    \str_case:nnF {#1}
      {
        { 1 }
          {
            \__mahjongtiles_warn_deprecated_no_aka:nn { no-aka=1 } { aka=0 }
            \int_gset:Nn \g__mahjongtiles_aka_int {0}
          }
        { true }
          {
            \__mahjongtiles_warn_deprecated_no_aka:nn { no-aka=true } { aka=0 }
            \int_gset:Nn \g__mahjongtiles_aka_int {0}
          }
        { 0 }
          {
            \__mahjongtiles_warn_deprecated_no_aka:nn { no-aka=0 } { aka=1 }
            \int_gset:Nn \g__mahjongtiles_aka_int {1}
          }
        { false }
          {
            \__mahjongtiles_warn_deprecated_no_aka:nn { no-aka=false } { aka=1 }
            \int_gset:Nn \g__mahjongtiles_aka_int {1}
          }
      }
      { \msg_error:nnn { mahjong-tiles } { invalid-no-aka } { no-aka=#1 } }
  }

\cs_new_protected:Npn \__mahjongtiles_set_no_aka_local:n #1
  {
    \str_case:nnF {#1}
      {
        { 1 }
          {
            \__mahjongtiles_warn_deprecated_no_aka:nn { no-aka=1 } { aka=0 }
            \int_set:Nn \g__mahjongtiles_aka_int {0}
          }
        { true }
          {
            \__mahjongtiles_warn_deprecated_no_aka:nn { no-aka=true } { aka=0 }
            \int_set:Nn \g__mahjongtiles_aka_int {0}
          }
        { 0 }
          {
            \__mahjongtiles_warn_deprecated_no_aka:nn { no-aka=0 } { aka=1 }
            \int_set:Nn \g__mahjongtiles_aka_int {1}
          }
        { false }
          {
            \__mahjongtiles_warn_deprecated_no_aka:nn { no-aka=false } { aka=1 }
            \int_set:Nn \g__mahjongtiles_aka_int {1}
          }
      }
      { \msg_error:nnn { mahjong-tiles } { invalid-no-aka } { no-aka=#1 } }
  }

\keys_define:nn { mahjong-tiles }
  {
    height   .dim_gset:N = \g__mahjongtiles_default_height_dim,
    scale    .fp_gset:N  = \g__mahjongtiles_default_scale_fp,
    tile-dir .tl_gset:N  = \g__mahjongtiles_tile_dir_tl,
    stick-dir .tl_gset:N = \g__mahjongtiles_stick_dir_tl,
    stick-dir .value_required:n = true,
    stick-height .dim_gset:N = \g__mahjongtiles_stick_height_dim,
    stick-height .value_required:n = true,
    stick-scale .fp_gset:N = \g__mahjongtiles_stick_scale_fp,
    stick-scale .value_required:n = true,
    stick-sep .dim_gset:N = \g__mahjongtiles_stick_sep_dim,
    stick-sep .value_required:n = true,
    river-cols .int_gset:N = \g__mahjongtiles_river_cols_int,
    river-cols .value_required:n = true,
    river-row-gap .dim_gset:N = \g__mahjongtiles_river_row_gap_dim,
    river-row-gap .value_required:n = true,
    overlay-style .tl_gset:N = \g__mahjongtiles_overlay_style_tl,
    overlay-style .value_required:n = true,

    color .code:n =
      { \__mahjongtiles_set_back_color_global:n {#1} },
    color .value_required:n = true,

    aka .code:n =
      { \__mahjongtiles_set_aka_global:n {#1} },
    aka .default:n = 1,

    no-aka .code:n =
      { \__mahjongtiles_set_no_aka_global:n {#1} },
    no-aka .default:n = 1,
  }
\ProcessKeysOptions { mahjong-tiles }

