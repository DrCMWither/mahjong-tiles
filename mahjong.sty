%% mahjong.sty -- Typeset Japanese/Riichi Mahjong tiles from compact MPSZ notation.
%% Refactored package implementation.  User-facing notation is kept compatible
%% with the original project: 123m456p, x, ?, -, ', ", plus the local * / +
%% rotation shorthands used by the test file.

\NeedsTeXFormat{LaTeX2e}[2020/10/01]
\RequirePackage{expl3}
\ProvidesExplPackage{mahjong}{2026/07/01}{1.4:.0}{Typeset Japanese Mahjong hands}

\RequirePackage{xparse}
\RequirePackage{l3keys2e}
\RequirePackage{graphicx}
\RequirePackage{xcolor}
\definecolor{mahjongbackred}{rgb}{1,0.215576,0.215576}
\RequirePackage{tikz}
\RequirePackage{stackengine}

\ExplSyntaxOn

% -----------------------------------------------------------------------------
% Messages
% -----------------------------------------------------------------------------
\msg_new:nnnn { mahjong } { invalid-token }
  { Token~'#1'~is~not~valid~in~Mahjong~MPSZ~notation. }
  { Valid~tokens~are~0--9,~m,~p,~s,~z,~x,~?,~-,~',~",~*,~+,~and~spaces. }

\msg_new:nnnn { mahjong } { unknown-tile }
  { I~cannot~find~tile~'#1'. }
  { Check~that~the~tile~PDF~exists~under~the~configured~tile-dir. }

\msg_new:nnnn { mahjong } { unknown-orientation }
  { Orientation~'#1'~is~unknown. }
  { This~is~an~internal~error;~valid~orientations~are~0,~1,~and~2. }

\msg_new:nnnn { mahjong } { missing-suit }
  { Tile~digit(s)~'#1'~do~not~have~a~suit. }
  { Add~m,~p,~s,~or~z~after~the~digit~group,~or~use~N-~for~a~separator. }

\msg_new:nnnn { mahjong } { missing-rotation-target }
  { Rotation~marker~'#1'~has~no~tile~to~rotate. }
  { Put~the~marker~after~a~digit,~x,~?,~or~a~completed~tile~group. }

\msg_new:nnnn { mahjong } { invalid-bool }
  { Boolean~option~'#1'~must~be~one~of~true,~false,~1,~0,~yes,~no,~on,~or~off. }
  { Use~for~example~no-aka=1~to~replace~red~fives~with~regular~fives. }

% -----------------------------------------------------------------------------
% Package options and state
% -----------------------------------------------------------------------------
\dim_new:N \g__mahjong_default_height_dim
\fp_new:N  \g__mahjong_default_scale_fp
\tl_new:N  \g__mahjong_tile_dir_tl

\dim_gset:Nn \g__mahjong_default_height_dim { \baselineskip }
\fp_gset:Nn  \g__mahjong_default_scale_fp  { 0.75 }
\tl_gset:Nn  \g__mahjong_tile_dir_tl       { tiles }

\tl_new:N   \g__mahjong_back_color_tl
\tl_new:N   \g__mahjong_back_filter_tl
\fp_new:N   \g__mahjong_back_opacity_fp
\bool_new:N \g__mahjong_back_recolor_bool
\bool_new:N \g__mahjong_no_aka_bool

\tl_gclear:N \g__mahjong_back_color_tl
\tl_gset:Nn  \g__mahjong_back_filter_tl { hue }
\fp_gset:Nn  \g__mahjong_back_opacity_fp { 1 }

\bool_gset_false:N \g__mahjong_back_recolor_bool
\bool_gset_false:N \g__mahjong_no_aka_bool

\cs_new_protected:Npn \__mahjong_set_back_color_global:n #1
  {
    \tl_if_blank:nTF {#1}
      {
        \tl_gclear:N \g__mahjong_back_color_tl
        \bool_gset_false:N \g__mahjong_back_recolor_bool
      }
      {
        \str_if_eq:nnTF {#1} { none }
          {
            \tl_gclear:N \g__mahjong_back_color_tl
            \bool_gset_false:N \g__mahjong_back_recolor_bool
          }
          {
            \tl_gset:Nn \g__mahjong_back_color_tl {#1}
            \bool_gset_true:N \g__mahjong_back_recolor_bool
          }
      }
  }

\cs_new_protected:Npn \__mahjong_set_back_color_local:n #1
  {
    \tl_if_blank:nTF {#1}
      {
        \tl_clear:N \g__mahjong_back_color_tl
        \bool_set_false:N \g__mahjong_back_recolor_bool
      }
      {
        \str_if_eq:nnTF {#1} { none }
          {
            \tl_clear:N \g__mahjong_back_color_tl
            \bool_set_false:N \g__mahjong_back_recolor_bool
          }
          {
            \tl_set:Nn \g__mahjong_back_color_tl {#1}
            \bool_set_true:N \g__mahjong_back_recolor_bool
          }
      }
  }

\cs_new_protected:Npn \__mahjong_set_no_aka_global:n #1
  {
    \str_case:nnF {#1}
      {
        { true }  { \bool_gset_true:N  \g__mahjong_no_aka_bool }
        { 1 }     { \bool_gset_true:N  \g__mahjong_no_aka_bool }
        { yes }   { \bool_gset_true:N  \g__mahjong_no_aka_bool }
        { on }    { \bool_gset_true:N  \g__mahjong_no_aka_bool }
        { false } { \bool_gset_false:N \g__mahjong_no_aka_bool }
        { 0 }     { \bool_gset_false:N \g__mahjong_no_aka_bool }
        { no }    { \bool_gset_false:N \g__mahjong_no_aka_bool }
        { off }   { \bool_gset_false:N \g__mahjong_no_aka_bool }
      }
      { \msg_error:nnn { mahjong } { invalid-bool } { no-aka=#1 } }
  }

\cs_new_protected:Npn \__mahjong_set_no_aka_local:n #1
  {
    \str_case:nnF {#1}
      {
        { true }  { \bool_set_true:N  \g__mahjong_no_aka_bool }
        { 1 }     { \bool_set_true:N  \g__mahjong_no_aka_bool }
        { yes }   { \bool_set_true:N  \g__mahjong_no_aka_bool }
        { on }    { \bool_set_true:N  \g__mahjong_no_aka_bool }
        { false } { \bool_set_false:N \g__mahjong_no_aka_bool }
        { 0 }     { \bool_set_false:N \g__mahjong_no_aka_bool }
        { no }    { \bool_set_false:N \g__mahjong_no_aka_bool }
        { off }   { \bool_set_false:N \g__mahjong_no_aka_bool }
      }
      { \msg_error:nnn { mahjong } { invalid-bool } { no-aka=#1 } }
  }

\keys_define:nn { mahjong }
  {
    height   .dim_gset:N = \g__mahjong_default_height_dim,
    scale    .fp_gset:N  = \g__mahjong_default_scale_fp,
    tile-dir .tl_gset:N  = \g__mahjong_tile_dir_tl,

    back-color .code:n =
      { \__mahjong_set_back_color_global:n {#1} },
    back-color .value_required:n = true,

    color .code:n =
      { \__mahjong_set_back_color_global:n {#1} },
    color .value_required:n = true,

    no-aka .code:n =
      { \__mahjong_set_no_aka_global:n {#1} },
    no-aka .default:n = true,

    back-filter .choice:,
    back-filter / hue .code:n =
      { \tl_gset:Nn \g__mahjong_back_filter_tl { hue } },
    back-filter / color .code:n =
      { \tl_gset:Nn \g__mahjong_back_filter_tl { color } },
    back-filter / multiply .code:n =
      { \tl_gset:Nn \g__mahjong_back_filter_tl { multiply } },
    back-filter / overlay .code:n =
      { \tl_gset:Nn \g__mahjong_back_filter_tl { overlay } },
    back-filter / normal .code:n =
      { \tl_gset:Nn \g__mahjong_back_filter_tl { normal } },

    back-opacity .fp_gset:N = \g__mahjong_back_opacity_fp,
  }
\ProcessKeysOptions { mahjong }

\dim_new:N \l__mahjong_tile_height_dim
\dim_new:N \l__mahjong_tile_width_dim
\dim_new:N \l__mahjong_symbol_height_dim
\dim_new:N \l__mahjong_baseline_offset_dim
\fp_new:N  \l__mahjong_tile_scale_fp

\seq_new:N \l__mahjong_tiles_seq
\seq_new:N \l__mahjong_pending_seq
\tl_new:N  \l__mahjong_pending_digits_tl
\tl_new:N  \l__mahjong_tmp_tl
\tl_new:N  \l__mahjong_tmpa_tl
\tl_new:N  \l__mahjong_tmpb_tl
\tl_new:N  \l__mahjong_first_face_tl
\tl_new:N  \l__mahjong_file_tl
\int_new:N \l__mahjong_tmp_int
\bool_new:N \l__mahjong_concealed_kong_bool

\keys_define:nn { mahjong / local }
  {
    height .dim_set:N = \l__mahjong_tile_height_dim,
    scale  .fp_set:N  = \l__mahjong_tile_scale_fp,

    back-color .code:n =
      { \__mahjong_set_back_color_local:n {#1} },
    back-color .value_required:n = true,

    color .code:n =
      { \__mahjong_set_back_color_local:n {#1} },
    color .value_required:n = true,

    no-aka .code:n =
      { \__mahjong_set_no_aka_local:n {#1} },
    no-aka .default:n = true,
  }

% -----------------------------------------------------------------------------
% Tuple helpers
% Pending tuple: {face}{orientation}
% Output tuple:  {kind}{a}{b}{c}
%   tile = {tile}{face}{suit}{orientation}; suit may be empty for x and ?
%   gap  = {gap}{n}{ }{ }; n means n/7 of one tile width
% -----------------------------------------------------------------------------
\cs_new_protected:Npn \__mahjong_pending_put:nn #1#2
  { \seq_put_right:Nn \l__mahjong_pending_seq { {#1} {#2} } }

\cs_new_protected:Npn \__mahjong_tile_put:nnn #1#2#3
  { \seq_put_right:Nn \l__mahjong_tiles_seq { { tile } {#1} {#2} {#3} } }
\cs_generate_variant:Nn \__mahjong_tile_put:nnn { Vnn }

\cs_new_protected:Npn \__mahjong_tile_put_aka_aware:nnn #1#2#3
  {
    \bool_if:NTF \g__mahjong_no_aka_bool
      {
        \str_if_eq:nnTF {#1} {0}
          {
            \tl_if_in:nnTF { mps } {#2}
              { \__mahjong_tile_put:nnn {5} {#2} {#3} }
              { \__mahjong_tile_put:nnn {#1} {#2} {#3} }
          }
          { \__mahjong_tile_put:nnn {#1} {#2} {#3} }
      }
      { \__mahjong_tile_put:nnn {#1} {#2} {#3} }
  }
\cs_generate_variant:Nn \__mahjong_tile_put_aka_aware:nnn { Vnn }

\cs_new_protected:Npn \__mahjong_gap_put:n #1
  { \seq_put_right:Nn \l__mahjong_tiles_seq { { gap } {#1} { } { } } }

\cs_new_protected:Npn \__mahjong_pending_set_last_orientation:n #1
  {
    \seq_pop_right:NNTF \l__mahjong_pending_seq \l__mahjong_tmp_tl
      { \exp_last_unbraced:NV \__mahjong_pending_set_last_orientation_aux:nnn \l__mahjong_tmp_tl {#1} }
      { \msg_error:nnn { mahjong } { missing-rotation-target } {#1} }
  }
\cs_new_protected:Npn \__mahjong_pending_set_last_orientation_aux:nnn #1#2#3
  { \seq_put_right:Nn \l__mahjong_pending_seq { {#1} {#3} } }

\cs_new_protected:Npn \__mahjong_output_set_last_orientation:n #1
  {
    \seq_pop_right:NNTF \l__mahjong_tiles_seq \l__mahjong_tmp_tl
      { \exp_last_unbraced:NV \__mahjong_output_set_last_orientation_aux:nnnnn \l__mahjong_tmp_tl {#1} }
      { \msg_error:nnn { mahjong } { missing-rotation-target } {#1} }
  }
\cs_new_protected:Npn \__mahjong_output_set_last_orientation_aux:nnnnn #1#2#3#4#5
  {
    \str_if_eq:nnTF {#1} { tile }
      { \seq_put_right:Nn \l__mahjong_tiles_seq { { tile } {#2} {#3} {#5} } }
      {
        \seq_put_right:Nn \l__mahjong_tiles_seq { {#1} {#2} {#3} {#4} }
        \msg_error:nnn { mahjong } { missing-rotation-target } {#5}
      }
  }

\cs_new_protected:Npn \__mahjong_set_last_orientation:n #1
  {
    \seq_if_empty:NTF \l__mahjong_pending_seq
      { \__mahjong_output_set_last_orientation:n {#1} }
      { \__mahjong_pending_set_last_orientation:n {#1} }
  }

% -----------------------------------------------------------------------------
% Parser
% -----------------------------------------------------------------------------
\cs_new_protected:Npn \__mahjong_parse:n #1
  {
    \seq_clear:N \l__mahjong_tiles_seq
    \seq_clear:N \l__mahjong_pending_seq
    \tl_set:Nx \l__mahjong_tmp_tl { \text_lowercase:n {#1} }
    \tl_map_inline:Nn \l__mahjong_tmp_tl
      { \__mahjong_parse_token:n {##1} }
    \seq_if_empty:NF \l__mahjong_pending_seq
      {
        \tl_clear:N \l__mahjong_pending_digits_tl
        \seq_map_inline:Nn \l__mahjong_pending_seq
          { \__mahjong_collect_pending_digits:nn ##1 }
        \msg_error:nnV { mahjong } { missing-suit } \l__mahjong_pending_digits_tl
      }
  }

\cs_new_protected:Npn \__mahjong_collect_pending_digits:nn #1#2
  { \tl_put_right:Nn \l__mahjong_pending_digits_tl {#1} }

\cs_new_protected:Npn \__mahjong_parse_token:n #1
  {
    \tl_if_blank:nTF {#1}
      { }
      {
        \tl_if_in:nnTF { 0123456789 } {#1}
          { \__mahjong_pending_put:nn {#1} {0} }
          {
            \tl_if_in:nnTF { mpsz } {#1}
              { \__mahjong_flush_suit:n {#1} }
              {
                \str_case:nnF {#1}
                  {
                    { - } { \__mahjong_handle_dash: }
                    { x } { \__mahjong_tile_put:nnn { x } { } {0} }
                    { ? } { \__mahjong_tile_put:nnn { ? } { } {0} }
                    { ' } { \__mahjong_set_last_orientation:n {1} }
                    { * } { \__mahjong_set_last_orientation:n {1} }
                    { " } { \__mahjong_set_last_orientation:n {2} }
                    { + } { \__mahjong_set_last_orientation:n {2} }
                  }
                  { \msg_error:nnn { mahjong } { invalid-token } {#1} }
              }
          }
      }
  }

\cs_new_protected:Npn \__mahjong_handle_dash:
  {
    \seq_if_empty:NTF \l__mahjong_pending_seq
      { \__mahjong_gap_put:n {7} }
      {
        \tl_clear:N \l__mahjong_pending_digits_tl
        \seq_map_inline:Nn \l__mahjong_pending_seq
          { \__mahjong_collect_pending_digits:nn ##1 }
        \__mahjong_gap_put:V \l__mahjong_pending_digits_tl
        \seq_clear:N \l__mahjong_pending_seq
      }
  }
\cs_generate_variant:Nn \__mahjong_gap_put:n { V }

\cs_new_protected:Npn \__mahjong_flush_suit:n #1
  {
    \seq_if_empty:NF \l__mahjong_pending_seq
      {
        \__mahjong_detect_concealed_kong:
        \bool_if:NTF \l__mahjong_concealed_kong_bool
          { \__mahjong_flush_concealed_kong:n {#1} }
          {
            \seq_map_inline:Nn \l__mahjong_pending_seq
              { \__mahjong_flush_pending_item:nnn ##1 {#1} }
          }
        \seq_clear:N \l__mahjong_pending_seq
      }
  }

\cs_new_protected:Npn \__mahjong_flush_pending_item:nnn #1#2#3
  { \__mahjong_tile_put_aka_aware:nnn {#1} {#3} {#2} }

\cs_new_protected:Npn \__mahjong_detect_concealed_kong:
  {
    \bool_set_false:N \l__mahjong_concealed_kong_bool
    \int_compare:nNnT { \seq_count:N \l__mahjong_pending_seq } = {5}
      {
        \seq_get_left:NN \l__mahjong_pending_seq \l__mahjong_tmp_tl
        \exp_last_unbraced:NV \__mahjong_remember_first_pending:nn \l__mahjong_tmp_tl
        \bool_set_true:N \l__mahjong_concealed_kong_bool
        \seq_map_inline:Nn \l__mahjong_pending_seq
          { \__mahjong_check_concealed_kong_item:nn ##1 }
      }
  }

\cs_new_protected:Npn \__mahjong_remember_first_pending:nn #1#2
  { \tl_set:Nn \l__mahjong_first_face_tl {#1} }

\cs_new_protected:Npn \__mahjong_check_concealed_kong_item:nn #1#2
  {
    \str_if_eq:VnF \l__mahjong_first_face_tl {#1}
      { \bool_set_false:N \l__mahjong_concealed_kong_bool }
    \int_compare:nNnF {#2} = {0}
      { \bool_set_false:N \l__mahjong_concealed_kong_bool }
  }

\cs_new_protected:Npn \__mahjong_flush_concealed_kong:n #1
  {
    % Five repeated digits followed by a suit are rendered as a concealed kong:
    % back, two visible tiles, back.  For 55555m/p/s the visible pair is red 5
    % plus normal 5 by default; no-aka=1 turns that visible pair into two
    % regular fives.
    \__mahjong_tile_put:nnn { x } { } {0}
    \str_if_eq:VnTF \l__mahjong_first_face_tl {5}
      {
        \tl_if_in:nnTF { mps } {#1}
          {
            \__mahjong_tile_put_aka_aware:nnn {0} {#1} {0}
            \__mahjong_tile_put_aka_aware:nnn {5} {#1} {0}
          }
          {
            \__mahjong_tile_put:nnn {5} {#1} {0}
            \__mahjong_tile_put:nnn {5} {#1} {0}
          }
      }
      {
        \__mahjong_tile_put_aka_aware:Vnn \l__mahjong_first_face_tl {#1} {0}
        \__mahjong_tile_put_aka_aware:Vnn \l__mahjong_first_face_tl {#1} {0}
      }
    \__mahjong_tile_put:nnn { x } { } {0}
  }

% -----------------------------------------------------------------------------
% Rendering
% -----------------------------------------------------------------------------
\cs_new:Npn \__mahjong_file:n #1
  { \g__mahjong_tile_dir_tl / mahjong-#1.pdf }

\cs_new_protected:Npn \__mahjong_render_hand:n #1
  {
    \dim_set:Nn \l__mahjong_symbol_height_dim
      { \fp_to_decimal:N \l__mahjong_tile_scale_fp \l__mahjong_tile_height_dim }
    \dim_set:Nn \l__mahjong_baseline_offset_dim
      { ( \l__mahjong_tile_height_dim - \l__mahjong_symbol_height_dim ) / 2 }
    \dim_set:Nn \l__mahjong_tile_width_dim
      { 0.75 \l__mahjong_tile_height_dim }
    \__mahjong_parse:n {#1}
    \leavevmode
    \raisebox { -\l__mahjong_baseline_offset_dim }
      { \seq_map_inline:Nn \l__mahjong_tiles_seq { \__mahjong_render_item:nnnn ##1 } }
  }

\cs_new_protected:Npn \__mahjong_render_item:nnnn #1#2#3#4
  {
    \str_if_eq:nnTF {#1} { gap }
      { \__mahjong_render_gap:n {#2} }
      { \__mahjong_render_tile:nnn {#2} {#3} {#4} }
  }

\cs_new_protected:Npn \__mahjong_render_gap:n #1
  { \hspace { \dim_eval:n { #1 \l__mahjong_tile_width_dim / 7 } } }

\cs_new_protected:Npn \__mahjong_render_tile:nnn #1#2#3
  {
    \str_case:nnF {#1}
      {
        { x } { \__mahjong_make_back_tile:n {#3} }
        { ? } { \__mahjong_make_symbol_tile:nn { \__mahjong_file:n { Blank } } {#3} }
      }
      {
        % Compatibility alias used by an older draft parser: 8z means a back tile.
        \str_if_eq:nnTF {#1#2} {8z}
          { \__mahjong_make_back_tile:n {#3} }
          { \__mahjong_make_symbol_tile:nn { \__mahjong_file:n { #1#2 } } {#3} }
      }
  }


  \cs_new_protected:Npn \__mahjong_make_symbol_tile:nn #1#2
  {
    \file_if_exist:nTF {#1}
      {
        \int_case:nnF {#2}
          {
            {0}
              {
                \stackinset { c } { 0pt } { c } { 0pt }
                  { \includegraphics [ height = \l__mahjong_symbol_height_dim ] {#1} }
                  { \includegraphics [ height = \l__mahjong_tile_height_dim ] { \__mahjong_file:n { Front } } }
              }
            {1}
              {
                \stackinset { c } { 0pt } { c } { 0pt }
                  { \includegraphics [ angle = 90, width = \l__mahjong_symbol_height_dim ] {#1} }
                  { \includegraphics [ angle = 90, width = \l__mahjong_tile_height_dim ] { \__mahjong_file:n { Front } } }
              }
            {2}
              {
                \stackon [0pt]
                  { \__mahjong_make_symbol_tile:nn {#1} {1} }
                  { \__mahjong_make_symbol_tile:nn {#1} {1} }
              }
          }
          {
            \msg_fatal:nnn { mahjong } { unknown-orientation } {#2}
          }
      }
      {
        \msg_error:nnn { mahjong } { unknown-tile } {#1}
      }
  }

\cs_new_protected:Npn \__mahjong_make_back_tile:n #1
  {
    \int_case:nnF {#1}
      {
        {0}
          {
            \__mahjong_make_back_tile_upright:
          }
        {1}
          {
            \rotatebox { 90 } { \__mahjong_make_back_tile_upright: }
          }
        {2}
          {
            \stackon [0pt]
              { \__mahjong_make_back_tile:n {1} }
              { \__mahjong_make_back_tile:n {1} }
          }
      }
      {
        \msg_fatal:nnn { mahjong } { unknown-orientation } {#1}
      }
  }

\cs_new_protected:Npn \__mahjong_make_back_tile_upright:
  {
    \bool_if:NTF \g__mahjong_back_recolor_bool
      {
        \__mahjong_make_back_tile_upright_recolored:
      }
      {
        \includegraphics
          [ height = \l__mahjong_tile_height_dim ]
          { \__mahjong_file:n { Back } }
      }
  }

% The back tile PDF is a single pure-red vector shape on a transparent
% background.  Recoloring by blending a rectangle over the whole PDF box leaks
% into the transparent rounded corners, so we redraw the exact vector outline as
% a clipping mask and fill only the visible shape.
\cs_new_protected:Npn \__mahjong_back_clip_path:
  {
    \path [ clip ]
      (30,300.059)
      -- (195.043,300.059)
      .. controls (211.664,300.059) and (225.043,286.68) .. (225.043,270.059)
      -- (225.043,29.477)
      .. controls (225.043,12.8551) and (211.664,-0.523047) .. (195.043,-0.523047)
      -- (30,-0.523047)
      .. controls (13.3789,-0.523047) and (0,12.8551) .. (0,29.477)
      -- (0,270.059)
      .. controls (0,286.68) and (13.3789,300.059) .. (30,300.059)
      -- cycle;
  }

\cs_new_protected:Npn \__mahjong_make_back_tile_upright_recolored:
  {
    \tikz
      [
        baseline = 0pt,
        x = { \dim_eval:n { \l__mahjong_tile_width_dim / 225 } },
        y = { \dim_eval:n { \l__mahjong_tile_height_dim / 300 } },
        inner~sep = 0pt,
        outer~sep = 0pt
      ]
      {
        \path [ use~as~bounding~box ] (0,0) rectangle (225,300);
        \begin{scope}
          \__mahjong_back_clip_path:
          \fill
            [
              \tl_use:N \g__mahjong_back_color_tl,
              opacity = \fp_to_decimal:N \g__mahjong_back_opacity_fp
            ]
            (0,-1) rectangle (226,301);
        \end{scope}
      }
  }

