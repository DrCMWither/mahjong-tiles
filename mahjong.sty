\cs_new_protected:Npn \mahjong_typeset_hand:n #1
  {
    \group_begin:
      \dim_set_eq:NN \l__mahjong_tile_height_dim \g__mahjong_default_height_dim
      \fp_set_eq:NN  \l__mahjong_tile_scale_fp  \g__mahjong_default_scale_fp
      \__mahjong_render_hand:n {#1}
    \group_end:
  }

\cs_new_protected:Npn \mahjong:n #1
  { \mahjong_typeset_hand:n {#1} }

% Compatibility with the parser prototype that exposed \mahjong_main:n.
\cs_new_protected:Npn \mahjong_main:n #1
  { \mahjong_typeset_hand:n {#1} }

\NewDocumentCommand \mahjong { O{\g__mahjong_default_height_dim} O{\g__mahjong_default_scale_fp} o O{} m }
  {
    \group_begin:
      \tl_if_in:nnTF {#1} { = }
        {
          \dim_set_eq:NN \l__mahjong_tile_height_dim \g__mahjong_default_height_dim
          \fp_set_eq:NN  \l__mahjong_tile_scale_fp  \g__mahjong_default_scale_fp
          \keys_set:nn { mahjong / local } {#1}
        }
        {
          \dim_set:Nn \l__mahjong_tile_height_dim {#1}
          \fp_set:Nn  \l__mahjong_tile_scale_fp  {#2}
          \IfNoValueF {#3}
            { \__mahjong_set_back_color_local:n {#3} }
        }
      \tl_if_blank:nF {#4}
        { \keys_set:nn { mahjong / local } {#4} }
      \__mahjong_render_hand:n {#5}
    \group_end:
  }

\NewDocumentCommand \mahjongsetup { m }
  {
    \keys_set:nn { mahjong } {#1}
  }

